      "query": {
        "query": "SELECT c FROM Customer c WHERE UPPER(c.firstName) LIKE UPPER(:firstName) ESCAPE '\\' OR UPPER(c.lastName) LIKE UPPER(:lastName) ESCAPE '\\'"
