      "name": "findByAppointment_IdOrderByScheduledTimeAsc",
      "signature": "public abstract java.util.List<com.generation.hairlab.model.AppointmentItem> com.generation.hairlab.repository.AppointmentItemRepository.findByAppointment_IdOrderByScheduledTimeAsc(java.lang.Integer)",
      "query": {
        "query": "SELECT a FROM AppointmentItem a WHERE a.appointment.id = :appointmentId ORDER BY a.scheduledTime asc"
      }
    },
    {
      "name": "findByEmployee_IdAndScheduledTimeBetweenOrderByScheduledTimeAsc",
