    {
      "name": "findByStartDateTimeBetweenOrderByStartDateTimeAsc",
      "signature": "public abstract java.util.List<com.generation.hairlab.model.Appointment> com.generation.hairlab.repository.AppointmentRepository.findByStartDateTimeBetweenOrderByStartDateTimeAsc(java.time.LocalDateTime,java.time.LocalDateTime)",
      "query": {
        "query": "SELECT a FROM Appointment a WHERE a.startDateTime BETWEEN :start AND :end ORDER BY a.startDateTime asc"
      }
