      "name": "findByCustomer_IdAndStatusOrderByStartDateTimeDesc",
      "signature": "public abstract java.util.List<com.generation.hairlab.model.Appointment> com.generation.hairlab.repository.AppointmentRepository.findByCustomer_IdAndStatusOrderByStartDateTimeDesc(java.lang.Integer,com.generation.hairlab.enums.AppointmentStatus)",
      "query": {
        "query": "SELECT a FROM Appointment a WHERE a.customer.id = :customerId AND a.status = :status ORDER BY a.startDateTime desc"
      }
    },
